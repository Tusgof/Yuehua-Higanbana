      "release_time_et": "14:00",
      "parser_status": "planned",
      "license_notes": "Official public Federal Reserve FOMC calendar and meeting materials."
    },
    {
      "source_id": "bls_release_calendar",
      "provider": "BLS",
      "source_url": "https://www.bls.gov/schedule/",
      "source_url_template": "https://www.bls.gov/schedule/{year}/home.htm",
      "event_types": ["CPI", "NFP", "PPI", "JOLTS"],
      "default_importance": "high",
      "release_time_et": "source_calendar",
      "parser_status": "planned",
      "license_notes": "Official public BLS schedule; source page states release times are Eastern Time."
    },
    {
      "source_id": "bea_release_schedule",
      "provider": "BEA",
      "source_url": "https://www.bea.gov/news/archive",
      "capture_mode": "bea_pce_release_pages",
      "output_extension": "json",
      "event_types": ["PCE", "GDP"],
      "default_importance": "high",
      "release_time_et": "source_calendar",
      "parser_status": "planned",
      "license_notes": "Official public BEA release schedule."
    },
    {
      "source_id": "ism_pmi_release_calendar",
      "provider": "ISM",
      "source_url": "https://www.ismworld.org/supply-management-news-and-reports/reports/rob-report-calendar/",
