      "license_notes": "Official ISM release calendar for Manufacturing and Services PMI reports."
    },
    {
      "source_id": "census_retail_release_schedule",
      "provider": "U.S. Census Bureau",
      "source_url": "https://www.census.gov/retail/marts/www/MARTSreleasedates.xls",
      "output_extension": "xls",
      "event_types": ["RETAIL_SALES"],
      "default_importance": "medium",
      "release_time_et": "source_calendar",
      "parser_status": "planned",
      "license_notes": "Official public Census release schedule for Monthly Retail Trade."
