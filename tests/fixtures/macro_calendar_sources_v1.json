    "FOMC_DECISION",
    "FOMC_MINUTES",
    "CPI",
    "NFP",
    "PCE",
    "JOLTS",
    "ISM_MANUFACTURING",
    "ISM_SERVICES",
    "RETAIL_SALES"
  ],
  "sources": [
