# SPY 0DTE - Higanbana environment template
# Do not commit real secrets. Copy to a local-only env file when needed.

# DeepSeek via OpenRouter
OPENROUTER_API_KEY_ENV=HIGANBANA_OPENROUTER_API
OPENROUTER_DEEPSEEK_MODEL_ID=deepseek/deepseek-v4-flash

# Data providers
OPTIONS_DATA_PROVIDER=UNSELECTED
OPTIONS_DATA_ROOT=D:\Fogust\Workspace\Investment\Project\SPY 0DTE - Higanbana\data\raw\spy_0dte
ALPHA_VANTAGE_API_KEY_ENV=ALPHA_VANTAGE_API_KEY
DATABENTO_API_KEY_ENV=DATABENTO_API_KEY
# Project-local and capped Databento aliases also supported for this workspace:
# DATABENTO_API_KEY_ENV=DATABENTO_SPY0DTE_API
# DATABENTO_API_KEY_ENV=DATABENTO_API_MO
# DATABENTO_API_KEY_ENV=DATABENTO_API_AI

# IBKR
IBKR_MODE=paper
IBKR_TRANSMIT_ENABLED=false
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1001

# Alerts
EMAIL_ALERTS_ENABLED=false
EMAIL_ALERTS_DRY_RUN=true
EMAIL_TO=user@example.com
